@model LoginViewModel

<section class="section bg-gray-100">
    <div class="container">
        <div class="row">
            <div class="col-lg-9 cell-inner">
                <div class="section-lg">
                    <h3 class="wow-outer"><span class="wow slideInDown">Login</span></h3>
                    <form method="POST" asp-action="Login" asp-controller="Auth" class="login-form">
                        <div class="login-form">
                            <div class="row">
                                <div asp-validation-summary="ModelOnly" class="col-md-12"></div>
                                <div class="col-md-12">
                                    <label>Email Address*</label>
                                    <input asp-for="Email" type="email" placeholder="Email Address" class="form-input" />
                                </div>
                                <div class="col-md-12">
                                    <label>Password</label>
                                    <input asp-for="Password" type="password" placeholder="Password" class="form-input" />
                                </div>
                                <div class="col-md-8">
                                    <div class="check-box">
                                        <input type="checkbox" id="remember_me" />
                                        <label for="remember_me">Remember me</label>
                                    </div>
                                </div>
                                <div class="col-md-4 pt-1 mt-md-0">
                                    <div class="forgotten-password_info">
                                        <a href="#"> Forgotten password?</a>
                                    </div>
                                </div>
                                <div class="col-md-12 pt-5">
                                    <button class="btn btn-custom-size lg-size btn-pronia-primary">Login</button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>